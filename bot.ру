async def find_filter(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    await query.edit_message_text(
        "🎭 **Введи маску**\n\n"
        "Пример: `a?b?c` — где `?` любая буква\n"
        "Отправь маску одним сообщением:"
    )
    context.user_data["awaiting_mask"] = True

async def handle_mask(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("awaiting_mask"):
        mask = update.message.text.strip()
        if len(mask) not in [5, 6] or not re.match(r'^[a-z?]+$', mask):
            await update.message.reply_text("❌ Неверный формат. Пример: a?b?c (5-6 символов, буквы и ?)")
            return
        context.user_data["awaiting_mask"] = False
        await find_free_tag(update, context, from_callback=False, mask=mask)

