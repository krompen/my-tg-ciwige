def find_partner(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    user = get_user(user_id)
    if not user:
        conn.close()
        return None
    
    # Получаем критерии поиска пользователя
    c.execute('SELECT search_gender FROM queue WHERE user_id = ?', (user_id,))
    queue_user = c.fetchone()
    search_gender = queue_user[0] if queue_user else "any"
    
    # Поиск партнёра с учётом критериев
    if search_gender == "male":
        c.execute('''SELECT queue.user_id FROM queue 
                     JOIN users ON queue.user_id = users.user_id
                     WHERE queue.user_id != ? 
                     AND users.gender = 'МУЖСКОЙ'
                     AND (queue.lang = ? OR ? = "ru")
                     ORDER BY queue.premium DESC, queue.joined_at ASC 
                     LIMIT 1''', (user_id, user[5], user[5]))
    elif search_gender == "female":
        c.execute('''SELECT queue.user_id FROM queue 
                     JOIN users ON queue.user_id = users.user_id
                     WHERE queue.user_id != ? 
                     AND users.gender = 'ЖЕНСКИЙ'
                     AND (queue.lang = ? OR ? = "ru")
                     ORDER BY queue.premium DESC, queue.joined_at ASC 
                     LIMIT 1''', (user_id, user[5], user[5]))
    else:
        c.execute('''SELECT user_id FROM queue 
                     WHERE user_id != ? 
                     AND (lang = ? OR ? = "ru")
                     ORDER BY premium DESC, joined_at ASC 
                     LIMIT 1''', (user_id, user[5], user[5]))
    
    partner = c.fetchone()
    conn.close()
    return partner[0] if partner else None

