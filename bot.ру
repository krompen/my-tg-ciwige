        await query.edit_message_text(text[:4000], reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
    elif data == "admin_blacklist_menu":
        await query.edit_message_text(
            "🚫 **ЧС тегов**\n\n/blacklist add <тег>\n/blacklist remove <тег>",
            reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]])
        )
    elif data == "admin_promo":
