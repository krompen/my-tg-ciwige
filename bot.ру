def main_keyboard(is_premium: bool = False, is_admin: bool = False):
    rows = [
        [KeyboardButton(text="🔍 Найти юзернейм"), KeyboardButton(text="⭐ Мой профиль")],
        [KeyboardButton(text="💎 Премиум"), KeyboardButton(text="🎲 Случайный юзернейм")],
        [KeyboardButton(text="📩 Поддержка")],
    ]
    if is_admin:
        rows.append([KeyboardButton(text="⚙️ Админ панель")])
    return ReplyKeyboardMarkup(keyboard=rows, resize_keyboard=True)


