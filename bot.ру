            "🎁 **Создать промокод**\n\n/promo_create <код> <1/2/3> <дни> <макс_исп>\nПример: /promo_create SUMMER 3 7 100",
            reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]])
