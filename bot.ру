async def handle_ticket_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("awaiting_ticket"):
        user_id = update.effective_user.id
        username = update.effective_user.username or "без юзернейма"
        question = update.message.text
        
        try:
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            c.execute('INSERT INTO tickets (user_id, username, question, status, created_at) VALUES (?, ?, ?, ?, ?)',
                      (user_id, username, question, 'open', now))
            ticket_id = c.lastrowid
            conn.commit()
            conn.close()
            
            await update.message.reply_text(f"✅ Запрос принят! Номер: #{ticket_id}\nОтветит @{ADMIN_USERNAME}")
            
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"🆕 **Новый тикет #{ticket_id}**\n👤 @{username} (ID: {user_id})\n📝 {question}\n💡 /answer {ticket_id} [текст]"
            )
        except:
            await update.message.reply_text("Ошибка, попробуй позже.")
        context.user_data["awaiting_ticket"] = False

