def set_premium(user_id, level, days):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        until = (datetime.datetime.now() + datetime.timedelta(days=days)).strftime("%Y-%m-%d")
        if level == 1:
