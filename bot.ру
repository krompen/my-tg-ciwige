def log_action(user_id, action):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO logs (user_id, action, time) VALUES (?, ?, ?)', (user_id, action, now))
        conn.commit()
