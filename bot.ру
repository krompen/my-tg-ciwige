def generate_god_tag():
    base = random.choice(GOD_TAGS)
    suffix = random.choice(["x", "z", "y", "v", "w", "ix", "ox", "ux"])
    return base + suffix

def generate_tag():
    word = random.choice(WORDS)
    modifications = [
        word,
        word[::-1],
        word + word[:2],
        word[1:] + word[0],
        word[2:] + word[:2],
    ]
    result = list(set(modifications))
    result = [w for w in result if len(w) >= 3 and len(w) <= 15]
    return random.choice(result) if result else word

