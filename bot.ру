def get_stats():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    total_users = c.execute('SELECT COUNT(*) FROM users').fetchone()[0]
    active_sessions = c.execute('SELECT COUNT(DISTINCT user_id) FROM sessions').fetchone()[0]
    pending_reports = c.execute('SELECT COUNT(*) FROM reports WHERE status = "pending"').fetchone()[0]
    conn.close()
    return total_users, active_sessions, pending_reports

def get_all_users():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    users = c.execute('SELECT user_id FROM users WHERE is_banned = 0').fetchall()
    conn.close()
    return users

