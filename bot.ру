async def confirm_manual(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    if len(context.args) < 3:
        await update.message.reply_text("❌ /confirm_manual <user_id> <level> <days>")
        return
    try:
        user_id = int(context.args[0])
        level = int(context.args[1])
        days = int(context.args[2])
        set_premium(user_id, level, days)
        await update.message.reply_text(f"✅ Премиум {get_premium_name(level)} на {days} дней выдан пользователю {user_id}.")
        await context.bot.send_message(chat_id=user_id, text=f"✅ Оплата подтверждена! Тебе выдан {get_premium_name(level)} на {days} дней.")
        log_action(ADMIN_ID, f"Подтвердил оплату для {user_id}, премиум {level} на {days} дней")
    except:
        await update.message.reply_text("❌ Ошибка.")

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    
    if data == "find_menu":
        await find_menu(update, context)
    elif data == "find":
        await find_random(update, context)
    elif data == "find_filter":
        await find_filter(update, context)
    elif data == "trap_menu":
        await trap_menu(update, context)
    elif data == "profile":
        await profile(update, context)
    elif data == "mytags":
        await mytags(update, context)
    elif data == "premium":
        await premium_menu(update, context)
    elif data.startswith("premium_buy"):
        parts = data.split("_")
        level = int(parts[2])
        days = int(parts[3])
        currency = parts[4]
        await premium_buy(update, context, level, days, currency)
    elif data == "shop":
        await shop_menu(update, context)
    elif data == "promo_menu":
        await promo_menu(update, context)
    elif data == "support":
        await support_menu(update, context)
    elif data == "admin":
        if query.from_user.id != ADMIN_ID:
            await query.edit_message_text("⛔ Нет доступа.")
            return
        keyboard = [
            [InlineKeyboardButton("📊 Статистика", callback_data="admin_stats")],
            [InlineKeyboardButton("📜 Логи", callback_data="admin_logs")],
            [InlineKeyboardButton("💎 Выдать премиум", callback_data="admin_give")],
            [InlineKeyboardButton("🚫 Бан/Разбан", callback_data="admin_ban")],
            [InlineKeyboardButton("🆘 Тикеты", callback_data="admin_tickets")],
            [InlineKeyboardButton("🚫 ЧС тегов", callback_data="admin_blacklist_menu")],
            [InlineKeyboardButton("🎁 Создать промокод", callback_data="admin_promo")],
            [InlineKeyboardButton("🛒 Добавить тег в магазин", callback_data="admin_add_shop")],
            [InlineKeyboardButton("🔙 Назад", callback_data="back")]
        ]
        await query.edit_message_text("👑 **Админ-панель**", reply_markup=InlineKeyboardMarkup(keyboard))
    elif data == "admin_stats":
        await admin_stats(update, context)
    elif data == "admin_logs":
        await admin_logs(update, context)
    elif data == "admin_give":
        await query.edit_message_text(
            "💎 **Выдача премиума**\n\n/givepremium <user_id> <1/2/3/4/5> <дни>",
            reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]])
        )
    elif data == "admin_ban":
        await query.edit_message_text(
            "🚫 **Бан/Разбан**\n\n/ban <user_id>\n/unban <user_id>",
            reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]])
        )
    elif data == "admin_tickets":
        await admin_tickets(update, context)
    elif data == "admin_blacklist_menu":
        await admin_blacklist_menu(update, context)
    elif data == "admin_promo":
        await admin_promo(update, context)
    elif data == "admin_add_shop":
        await admin_add_shop(update, context)
    elif data == "back":
        class FakeUpdate:
            def __init__(self, user):
                self.effective_user = user
                self.message = type('obj', (object,), {'reply_text': query.edit_message_text})
        fake_user = type('obj', (object,), {'id': query.from_user.id, 'username': query.from_user.username, 'first_name': query.from_user.first_name})
        fake_update = FakeUpdate(fake_user)
        await start(fake_update, context)

