# ========== ГЕНЕРАЦИЯ ТЕГОВ ==========
LETTERS = "abcdefghijklmnopqrstuvwxyz"
def generate_tag_by_length(length):
    return ''.join(random.choice(LETTERS) for _ in range(length))

def generate_tag_by_mask(mask):
    result = []
    for ch in mask:
        if ch == '?':
            result.append(random.choice(LETTERS))
        else:
            result.append(ch)
    return ''.join(result)

