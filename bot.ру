        elif level == 2:
            requests = 20
        else:
            requests = 999999
        c.execute('UPDATE users SET premium_level = ?, premium_until = ?, daily_requests = ? WHERE user_id = ?', 
                  (level, until, requests, user_id))
        conn.commit()
        conn.close()
        log_action(ADMIN_ID, f"Выдал премиум {level} на {days} дней пользователю {user_id}")
