async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    user = update.effective_user
    add_user(user.id, user.username or str(user.id))
    check_premium_expired()
    
    user_data = get_user(user.id)
    if user_data and user_data[10] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[11]}", reply_markup=back_keyboard())
        return
    
    await update.message.reply_text(
        "✨ ДОБРО ПОЖАЛОВАТЬ В АНОНИМНЫЙ ЧАТ! ✨\n\n"
        "🔍 НАЙДИ СОБЕСЕДНИКА\n"
        "💬 ОБЩАЙСЯ АНОНИМНО\n"
        "⭐ ОЦЕНИВАЙ СОБЕСЕДНИКОВ\n\n"
        "⬇️ **ВЫБИРАЙ ДЕЙСТВИЕ:**",
        reply_markup=main_keyboard(user.id),
        parse_mode="Markdown"
    )

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    user_data = get_user(user_id)
    
    if user_data and user_data[10] == 1:
        await query.edit_message_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[11]}", reply_markup=back_keyboard())
        return
    
    # ========== ГЛАВНОЕ МЕНЮ ==========
    if data == "back":
        context.user_data.clear()
        await query.edit_message_text(
            "✨ ГЛАВНОЕ МЕНЮ ✨\n\n⬇️ ВЫБИРАЙ ДЕЙСТВИЕ:",
            reply_markup=main_keyboard(user_id)
        )
    
    elif data == "noop":
        return
    
    # ========== ПОИСК СОБЕСЕДНИКА ==========
    elif data == "search":
        if is_in_session(user_id):
            await query.edit_message_text("❌ ВЫ УЖЕ В ДИАЛОГЕ!\nСНАЧАЛА ЗАКОНЧИТЕ ТЕКУЩИЙ ЧАТ.", reply_markup=main_keyboard(user_id))
            return
        
        # Получаем критерии поиска
        search_gender = context.user_data.get("search_gender", "any")
        
        await query.edit_message_text("🔍 ИЩЕМ СОБЕСЕДНИКА...\n\n⏳ ПОЖАЛУЙСТА, ПОДОЖДИТЕ.", reply_markup=back_keyboard())
        
        add_to_queue(user_id, search_gender)
        partner = find_partner(user_id)
        
        if partner:
            remove_from_queue(user_id)
            remove_from_queue(partner)
            create_session(user_id, partner)
            
            partner_data = get_user(partner)
            is_premium = "👑 PREMIUM" if partner_data[6] == 1 else "🆓 ОБЫЧНЫЙ"
            
            await query.edit_message_text(
                f"✅ СОБЕСЕДНИК НАЙДЕН!\n\n"
                f"📝 О НЁМ: {partner_data[2]}, {partner_data[3]} лет, {partner_data[4]}\n"
                f"⭐ РЕЙТИНГ: {partner_data[8]:.1f}/5\n"
                f"💎 СТАТУС: {is_premium}\n\n"
                f"💬 ТЕПЕРЬ ВЫ МОЖЕТЕ ОБЩАТЬСЯ!\n"
                f"❌ ДЛЯ ЗАВЕРШЕНИЯ НАЖМИТЕ «ЗАКОНЧИТЬ ДИАЛОГ»",
                reply_markup=main_keyboard(user_id)
            )
            
            await context.bot.send_message(
                chat_id=partner,
                text=f"✅ СОБЕСЕДНИК НАЙДЕН!\n\n"
                     f"📝 О ВАС: {user_data[2]}, {user_data[3]} лет, {user_data[4]}\n"
                     f"⭐ РЕЙТИНГ: {user_data[8]:.1f}/5\n"
                     f"💎 СТАТУС: {'👑 PREMIUM' if user_data[6] == 1 else '🆓 ОБЫЧНЫЙ'}\n\n"
                     f"💬 ТЕПЕРЬ ВЫ МОЖЕТЕ ОБЩАТЬСЯ!\n"
