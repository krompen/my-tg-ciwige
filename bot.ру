async def give_premium(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 3:
        await update.message.reply_text("❌ /givepremium <user_id> <1/2/3> <дни>")
        return
    try:
        target_id = int(context.args[0])
        level = int(context.args[1])
        days = int(context.args[2])
        set_premium(target_id, level, days)
        level_name = {1:"Базовый",2:"Плюс",3:"VIP"}[level]
        await update.message.reply_text(f"✅ Пользователь {target_id} получил премиум {level_name} на {days} дней.")
        try:
            await context.bot.send_message(chat_id=target_id, text=f"🎉 Тебе выдан премиум {level_name} на {days} дней!")
        except:
            pass
    except:
        await update.message.reply_text("❌ Неверные данные.")

async def answer_ticket(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 2:
        await update.message.reply_text("❌ /answer <ticket_id> <текст>")
        return
    try:
        ticket_id = int(context.args[0])
        answer = " ".join(context.args[1:])
        
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id, question FROM tickets WHERE id = ?', (ticket_id,))
        ticket = c.fetchone()
        if not ticket:
            await update.message.reply_text("❌ Тикет не найден.")
            return
        
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('UPDATE tickets SET status = "closed", admin_answer = ?, answered_at = ? WHERE id = ?', 
                  (answer, now, ticket_id))
        conn.commit()
        conn.close()
        
        await update.message.reply_text(f"✅ Ответ на тикет #{ticket_id} отправлен.")
        await context.bot.send_message(
            chat_id=ticket[0],
            text=f"📬 **Ответ на обращение #{ticket_id}**\n\n❓ {ticket[1]}\n\n✅ {answer}"
        )
    except:
        await update.message.reply_text("❌ Ошибка.")

