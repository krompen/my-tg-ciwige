def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        gender TEXT DEFAULT 'не указан',
        age INTEGER DEFAULT 0,
        lang TEXT DEFAULT 'ru',
        premium INTEGER DEFAULT 0,
        rating REAL DEFAULT 0,
        rating_count INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0,
        ban_reason TEXT DEFAULT NULL,
        registered_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS sessions (
        user_id INTEGER,
        partner_id INTEGER,
        start_time TEXT,
        PRIMARY KEY (user_id, partner_id)
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS queue (
        user_id INTEGER,
        gender TEXT,
        lang TEXT,
        premium INTEGER,
        joined_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS reports (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        reporter_id INTEGER,
        reported_id INTEGER,
        reason TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS feedback (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        rating INTEGER,
        comment TEXT,
        created_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS bot_settings (
        key TEXT PRIMARY KEY,
        value TEXT
    )''')
    
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("search_timeout", "30")')
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("message_limit", "5")')
    
    c.execute('INSERT OR IGNORE INTO users (user_id, username, registered_at) VALUES (?, ?, ?)', 
              (ADMIN_ID, 'ciwige', datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    
    conn.commit()
    conn.close()

init_db()

# ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========
def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, gender, age, lang, premium, rating, rating_count, is_banned, ban_reason FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def add_user(user_id, username):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, registered_at) VALUES (?, ?, ?)', (user_id, username, now))
    conn.commit()
    conn.close()

def update_user_profile(user_id, gender, age):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET gender = ?, age = ? WHERE user_id = ?', (gender, age, user_id))
    conn.commit()
    conn.close()

def update_user_lang(user_id, lang):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET lang = ? WHERE user_id = ?', (lang, user_id))
    conn.commit()
    conn.close()

def add_to_queue(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    user = get_user(user_id)
    if not user:
        conn.close()
        return
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO queue (user_id, gender, lang, premium, joined_at) VALUES (?, ?, ?, ?, ?)',
              (user_id, user[2], user[4], user[5], now))
    conn.commit()
    conn.close()

def remove_from_queue(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('DELETE FROM queue WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()

def find_partner(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    user = get_user(user_id)
    if not user:
        conn.close()
        return None
    
    # Поиск партнёра: приоритет премиум, потом совпадение по языку, потом любой
    c.execute('''SELECT user_id FROM queue 
                 WHERE user_id != ? 
                 AND (lang = ? OR ? = "ru")
                 ORDER BY premium DESC, joined_at ASC 
                 LIMIT 1''', (user_id, user[4], user[4]))
    partner = c.fetchone()
    conn.close()
    return partner[0] if partner else None

def create_session(user_id, partner_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR REPLACE INTO sessions (user_id, partner_id, start_time) VALUES (?, ?, ?)', (user_id, partner_id, now))
    c.execute('INSERT OR REPLACE INTO sessions (user_id, partner_id, start_time) VALUES (?, ?, ?)', (partner_id, user_id, now))
    conn.commit()
    conn.close()

def get_partner(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT partner_id FROM sessions WHERE user_id = ?', (user_id,))
    partner = c.fetchone()
    conn.close()
    return partner[0] if partner else None

def delete_session(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    # Удаляем сессию для обоих
    c.execute('SELECT partner_id FROM sessions WHERE user_id = ?', (user_id,))
    partner = c.fetchone()
    if partner:
        c.execute('DELETE FROM sessions WHERE user_id = ?', (partner[0],))
    c.execute('DELETE FROM sessions WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()

def is_in_session(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT partner_id FROM sessions WHERE user_id = ?', (user_id,))
    partner = c.fetchone()
    conn.close()
    return partner is not None

def add_rating(user_id, rating):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    user = get_user(user_id)
    if user:
        new_rating = (user[6] * user[7] + rating) / (user[7] + 1)
        c.execute('UPDATE users SET rating = ?, rating_count = rating_count + 1 WHERE user_id = ?', (new_rating, user_id))
        conn.commit()
    conn.close()

def create_report(reporter_id, reported_id, reason):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO reports (reporter_id, reported_id, reason, created_at) VALUES (?, ?, ?, ?)',
              (reporter_id, reported_id, reason, now))
    report_id = c.lastrowid
    conn.commit()
    conn.close()
    return report_id

def get_pending_reports():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    reports = c.execute('SELECT id, reporter_id, reported_id, reason, created_at FROM reports WHERE status = "pending" ORDER BY id DESC').fetchall()
    conn.close()
    return reports

def resolve_report(report_id, status):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE reports SET status = ? WHERE id = ?', (status, report_id))
    conn.commit()
    conn.close()

def ban_user(user_id, reason):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET is_banned = 1, ban_reason = ? WHERE user_id = ?', (reason, user_id))
    conn.commit()
