async def is_tag_available(tag):
    await asyncio.sleep(0.1)
    return random.random() > 0.7

# ========== ГЕНЕРАЦИЯ ТЕГОВ ==========
LETTERS = "abcdefghijklmnopqrstuvwxyz"
def generate_tag_by_length(length):
    return ''.join(random.choice(LETTERS) for _ in range(length))

def generate_tag_by_mask(mask):
    result = []
    for ch in mask:
        if ch == '?':
            result.append(random.choice(LETTERS))
        else:
            result.append(ch)
    return ''.join(result)

async def find_free_tag(update: Update, context: ContextTypes.DEFAULT_TYPE, from_callback=False, length=None, mask=None):
    user_id = update.effective_user.id if hasattr(update, 'effective_user') else update.from_user.id
    user = get_user(user_id, update.effective_user.username if hasattr(update, 'effective_user') else update.from_user.username)
    
    if not use_request(user_id):
        remaining = get_remaining_requests(user_id)
        msg = f"❌ Лимит на сегодня ({remaining}). Хочешь больше? лутай премиум в лс @{ADMIN_USERNAME}"
        if from_callback:
            await update.edit_message_text(msg)
        else:
            await update.message.reply_text(msg)
        return
    
    if from_callback:
        msg = await update.edit_message_text("🔍 Ищу тег...")
    else:
        msg = await update.message.reply_text("🔍 Ищу тег...")
    
    await asyncio.sleep(0.5)
    
    found = False
    attempts = 0
    tag = ""
    
    while not found and attempts < 50:
        if mask:
            tag = generate_tag_by_mask(mask)
        elif length:
            tag = generate_tag_by_length(length)
        else:
            tag = generate_tag_by_length(random.choice([5, 6]))
        if is_tag_blacklisted(tag):
            attempts += 1
            continue
        found = await is_tag_available(tag)
        attempts += 1
    
    if found:
        save_found_tag(user_id, tag)
        remaining = get_remaining_requests(user_id)
        premium_name = get_premium_name(user[2] if user else 0)
        await msg.edit_text(
            f"✅ **Ник найден!**\n\n"
            f"📝 **Ник** - @{tag} › `{tag}`\n"
            f"├ 🟢 **Ликвидность** - {random.randint(8,10)} из 10 ⭐\n"
            f"╰ ⚡ **Свободен**\n\n"
            f"🤍 **Осталось запросов:** {remaining}\n"
            f"💎 **Статус:** {premium_name}\n\n"
            f"💰 Забрать ник можно в лс @{ADMIN_USERNAME}"
        )
    else:
        await msg.edit_text(
            f"❌ Свободных тегов не найдено.\nПопробуй другой фильтр или лови премиум у @{ADMIN_USERNAME}"
        )

