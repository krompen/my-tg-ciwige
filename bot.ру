            f"❌ Ты исчерпал лимит запросов на сегодня ({remaining}).\n"
            f"Лимит обнулится завтра, или купи премиум у @{ADMIN_USERNAME}."
        )
        return
    
    msg = await update.message.reply_text("🔍 Ищу свободный тег...")
