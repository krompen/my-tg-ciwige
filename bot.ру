            return user
        
        if user[3]:
            try:
                premium_until = datetime.datetime.strptime(user[3], "%Y-%m-%d")
                if premium_until < datetime.datetime.now():
                    conn = sqlite3.connect(DB_NAME, timeout=10)
                    c = conn.cursor()
                    c.execute('UPDATE users SET premium_level = 0, premium_until = NULL WHERE user_id = ?', (user_id,))
                    conn.commit()
                    conn.close()
                    return get_user(user_id, username)
            except:
                pass
        
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        if user[5] != today:
            if user[2] == 5:
                requests = 999999
            elif user[2] == 4:
                requests = 999999
            elif user[2] == 3:
                requests = 999999
            elif user[2] == 2:
                requests = 20
            elif user[2] == 1:
                requests = 10
            else:
                requests = 5
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('UPDATE users SET daily_requests = ?, last_reset = ? WHERE user_id = ?', (requests, today, user_id))
            conn.commit()
            conn.close()
            return get_user(user_id, username)
        
        if user[9] != today:
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('UPDATE users SET daily_requests = daily_requests + 1, daily_bonus_last = ? WHERE user_id = ?', (today, user_id))
            conn.commit()
            conn.close()
            return get_user(user_id, username)
        
        return user
    except:
        return None

