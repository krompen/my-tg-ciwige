def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        premium_level INTEGER DEFAULT 0,
        premium_until TEXT,
        daily_requests INTEGER DEFAULT 5,
        last_reset TEXT,
        total_requests INTEGER DEFAULT 0
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS found_tags (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        tag TEXT,
        found_date TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS tickets (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        username TEXT,
        question TEXT,
        status TEXT DEFAULT 'open',
        created_at TEXT,
        admin_answer TEXT,
        answered_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS logs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        action TEXT,
        time TEXT
    )''')
    conn.commit()
    conn.close()

def log_action(user_id, action):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO logs (user_id, action, time) VALUES (?, ?, ?)', (user_id, action, now))
        conn.commit()
        conn.close()
    except:
        pass

def get_user(user_id, username=""):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id, username, premium_level, premium_until, daily_requests, last_reset, total_requests FROM users WHERE user_id = ?', (user_id,))
        user = c.fetchone()
        conn.close()
        
        if not user:
            add_user(user_id, username)
            return get_user(user_id, username)
        
        # Проверка истечения премиума
        if user[3]:
            try:
                premium_until = datetime.datetime.strptime(user[3], "%Y-%m-%d")
                if premium_until < datetime.datetime.now():
                    conn = sqlite3.connect(DB_NAME, timeout=10)
                    c = conn.cursor()
                    c.execute('UPDATE users SET premium_level = 0, premium_until = NULL WHERE user_id = ?', (user_id,))
                    conn.commit()
                    conn.close()
                    return get_user(user_id, username)
            except:
                pass
        
        # Сброс дневных лимитов
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        if user[5] != today:
            if user[2] == 3:
                requests = 999999
            elif user[2] == 2:
                requests = 20
            elif user[2] == 1:
                requests = 10
            else:
                requests = 5
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('UPDATE users SET daily_requests = ?, last_reset = ? WHERE user_id = ?', (requests, today, user_id))
            conn.commit()
            conn.close()
            return get_user(user_id, username)
        return user
    except:
        return None

def add_user(user_id, username):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        c.execute('INSERT OR IGNORE INTO users (user_id, username, premium_level, daily_requests, last_reset, total_requests) VALUES (?, ?, 0, 5, ?, 0)',
                  (user_id, username, today))
        conn.commit()
        conn.close()
        log_action(user_id, "Зарегистрировался")
    except:
        pass

def set_premium(user_id, level, days):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        until = (datetime.datetime.now() + datetime.timedelta(days=days)).strftime("%Y-%m-%d")
        if level == 1:
            requests = 10
        elif level == 2:
            requests = 20
        else:
            requests = 999999
        c.execute('UPDATE users SET premium_level = ?, premium_until = ?, daily_requests = ? WHERE user_id = ?', 
                  (level, until, requests, user_id))
        conn.commit()
        conn.close()
        log_action(ADMIN_ID, f"Выдал премиум {level} на {days} дней пользователю {user_id}")
    except:
        pass

def use_request(user_id):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        user = get_user(user_id)
        if not user or user[2] == 3:
            conn.close()
            return True
        current = user[4]
        if current <= 0:
            conn.close()
            return False
        c.execute('UPDATE users SET daily_requests = daily_requests - 1, total_requests = total_requests + 1 WHERE user_id = ?', (user_id,))
        conn.commit()
        conn.close()
        return True
    except:
        return False

