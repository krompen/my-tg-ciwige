async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    user_data = get_user(user_id)
    
    if user_data and user_data[10] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[11]}", reply_markup=back_keyboard())
        return
    
    # ========== РАССЫЛКА ==========
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 **РАССЫЛКА ОТ АДМИНА**\n\n{text}", parse_mode="Markdown")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # ========== ВЫДАЧА PREMIUM ==========
    if context.user_data.get("awaiting_give_premium") and is_admin(user_id):
        try:
            parts = text.split()
            target_id = int(parts[0])
            days = int(parts[1])
            give_premium(target_id, days)
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЮ {target_id} ВЫДАН PREMIUM НА {days} ДНЕЙ!", reply_markup=main_keyboard(user_id))
            await context.bot.send_message(chat_id=target_id, text=f"👑 ВАМ ВЫДАН PREMIUM СТАТУС НА {days} ДНЕЙ!\n\nТЕПЕРЬ ВАМ ДОСТУПНЫ КРИТЕРИИ ПОИСКА И ГОЛОСОВЫЕ СООБЩЕНИЯ!")
            context.user_data["awaiting_give_premium"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ФОРМАТ: `ID ДНЕЙ`", reply_markup=back_keyboard())
        return
    
    # ========== РЕДАКТИРОВАНИЕ ВОЗРАСТА ==========
    if context.user_data.get("awaiting_age"):
        try:
            age = int(text)
            if 18 <= age <= 99:
                user = get_user(user_id)
                update_user_profile(user_id, user[2], age, user[4])
                await update.message.reply_text(f"✅ ВОЗРАСТ ИЗМЕНЁН НА: {age}", reply_markup=main_keyboard(user_id))
            else:
                await update.message.reply_text("❌ ВОЗРАСТ ДОЛЖЕН БЫТЬ ОТ 18 ДО 99!", reply_markup=back_keyboard())
            context.user_data["awaiting_age"] = False
        except:
            await update.message.reply_text("❌ ВВЕДИТЕ ЧИСЛО!", reply_markup=back_keyboard())
        return
    
    # ========== РЕДАКТИРОВАНИЕ ГОРОДА ==========
    if context.user_data.get("awaiting_city"):
        city = text[:50]
        user = get_user(user_id)
        update_user_profile(user_id, user[2], user[3], city)
        await update.message.reply_text(f"✅ ГОРОД ИЗМЕНЁН НА: {city}", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_city"] = False
        return
    
    # ========== ОТЗЫВ О БОТЕ ==========
    if context.user_data.get("awaiting_feedback"):
        rating = context.user_data["awaiting_feedback"]
        comment = text if text != "-" else ""
        add_feedback(user_id, rating, comment)
        await update.message.reply_text(f"✅ СПАСИБО ЗА ОТЗЫВ!\n⭐ ОЦЕНКА: {rating}/5", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_feedback"] = False
        return
    
    # ========== ЖАЛОБА ==========
    if context.user_data.get("awaiting_report"):
        partner = get_partner(user_id)
        if partner:
            create_report(user_id, partner, text)
            await update.message.reply_text("✅ ЖАЛОБА ОТПРАВЛЕНА АДМИНИСТРАЦИИ!\nСПАСИБО ЗА СИГНАЛ.", reply_markup=main_keyboard(user_id))
        else:
            await update.message.reply_text("❌ ОШИБКА! СОБЕСЕДНИК НЕ НАЙДЕН.", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_report"] = False
        return
    
    # ========== БАН/РАЗБАН ==========
    if context.user_data.get("awaiting_admin_ban") and is_admin(user_id):
        try:
            target_id = int(text)
            user = get_user(target_id)
            if user and user[10] == 1:
                unban_user(target_id)
                await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {target_id} РАЗБАНЕН!", reply_markup=main_keyboard(user_id))
                await context.bot.send_message(chat_id=target_id, text="✅ ВЫ РАЗБАНЕНЫ В БОТЕ!")
            else:
                await update.message.reply_text(f"📝 ВВЕДИТЕ ПРИЧИНУ БАНА ДЛЯ {target_id}:", reply_markup=back_keyboard())
                context.user_data["ban_target"] = target_id
                context.user_data["awaiting_ban_reason"] = True
            context.user_data["awaiting_admin_ban"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ВВЕДИТЕ ID ПОЛЬЗОВАТЕЛЯ.")
        return
    
    if context.user_data.get("awaiting_ban_reason") and is_admin(user_id):
        target_id = context.user_data["ban_target"]
        reason = text
        ban_user(target_id, reason)
        await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {target_id} ЗАБАНЕН!\nПРИЧИНА: {reason}", reply_markup=main_keyboard(user_id))
        await context.bot.send_message(chat_id=target_id, text=f"🚫 ВЫ ЗАБАНЕНЫ В БОТЕ!\nПРИЧИНА: {reason}")
        context.user_data["awaiting_ban_reason"] = False
        context.user_data["ban_target"] = None
        return
    
    # ========== КОМАНДЫ АДМИНА ==========
    if text.startswith("/set_premium_price") and is_admin(user_id):
        try:
            parts = text.split()
            new_price = int(parts[1])
            update_setting("premium_price", new_price)
            await update.message.reply_text(f"✅ ЦЕНА PREMIUM ИЗМЕНЕНА НА {new_price}⭐!", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /set_premium_price <цена>")
        return
    
    if text.startswith("/set_gift_receiver") and is_admin(user_id):
        try:
            parts = text.split()
            receiver_id = int(parts[1])
            update_setting("gift_receiver", receiver_id)
            await update.message.reply_text(f"✅ ПОЛУЧАТЕЛЬ ПОДАРКОВ УСТАНОВЛЕН: {receiver_id}!", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /set_gift_receiver <ID>")
        return
    
    if text.startswith("/create_fake") and is_admin(user_id):
        try:
            parts = text.split()
            user1_id = int(parts[1])
            user2_id = int(parts[2])
            dialog_id = create_fake_dialog(user1_id, user2_id)
            await update.message.reply_text(f"✅ ФЕЙК ДИАЛОГ #{dialog_id} СОЗДАН!\n{user1_id} ↔ {user2_id}", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /create_fake <ID1> <ID2>")
        return
    
    if text.startswith("/delete_fake") and is_admin(user_id):
        try:
            parts = text.split()
            dialog_id = int(parts[1])
            delete_fake_dialog(dialog_id)
            await update.message.reply_text(f"✅ ФЕЙК ДИАЛОГ #{dialog_id} УДАЛЁН!", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /delete_fake <ID>")
        return
    
    # ========== ПЕРЕСЫЛКА СООБЩЕНИЙ В ЧАТЕ ==========
    partner = get_partner(user_id)
    if partner:
        user = get_user(user_id)
        is_premium = user[6] == 1 if user else False
        
        # Проверка на голосовые/кружки (только для премиум)
        if update.message.voice or update.message.video_note:
            if not is_premium:
                await update.message.reply_text("❌ ОТПРАВКА ГОЛОСОВЫХ И КРУЖКОВ ДОСТУПНА ТОЛЬКО ДЛЯ PREMIUM!\nКУПИТЕ PREMIUM В МЕНЮ.", reply_markup=main_keyboard(user_id))
                return
        
        # Пересылаем сообщение партнёру
        if update.message.text:
            await context.bot.send_message(
                chat_id=partner,
                text=f"👤 **СОБЕСЕДНИК:**\n{text}",
                parse_mode="Markdown"
            )
        elif update.message.voice:
            await context.bot.send_voice(chat_id=partner, voice=update.message.voice.file_id)
            await context.bot.send_message(chat_id=partner, text="🎤 **ГОЛОСОВОЕ СООБЩЕНИЕ ОТ СОБЕСЕДНИКА**", parse_mode="Markdown")
        elif update.message.video_note:
            await context.bot.send_video_note(chat_id=partner, video_note=update.message.video_note.file_id)
            await context.bot.send_message(chat_id=partner, text="🔄 **КРУЖОК ОТ СОБЕСЕДНИКА**", parse_mode="Markdown")
        elif update.message.photo:
            await context.bot.send_photo(chat_id=partner, photo=update.message.photo[-1].file_id)
            await context.bot.send_message(chat_id=partner, text="📸 **ФОТО ОТ СОБЕСЕДНИКА**", parse_mode="Markdown")
        
        await update.message.reply_text("✅ СООБЩЕНИЕ ОТПРАВЛЕНО!", reply_markup=main_keyboard(user_id))
    else:
        await update.message.reply_text(
            "❌ ВЫ НЕ В ДИАЛОГЕ!\n\n"
            "🔍 НАЖМИТЕ «НАЙТИ СОБЕСЕДНИКА» ЧТОБЫ НАЧАТЬ ЧАТ.",
            reply_markup=main_keyboard(user_id)
        )

# ========== ПЛАТЕЖИ ==========
async def pre_checkout_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.pre_checkout_query
    await query.answer(ok=True)

async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    payload = update.message.successful_payment.invoice_payload
    
    if payload == "premium_30days":
        give_premium(user_id, 30)
        await update.message.reply_text(
            "✅ **ОПЛАТА ПРОШЛА УСПЕШНО!**\n\n"
            "👑 ВАМ ВЫДАН PREMIUM СТАТУС НА 30 ДНЕЙ!\n\n"
            "🔹 ТЕПЕРЬ ВАМ ДОСТУПНО:\n"
            "• 🎯 ВЫБОР КРИТЕРИЕВ ПОИСКА\n"
            "• 🎤 ОТПРАВКА ГОЛОСОВЫХ СООБЩЕНИЙ\n"
            "• 🔄 ПРИОРИТЕТНЫЙ ПОИСК\n\n"
            "СПАСИБО ЗА ПОДДЕРЖКУ БОТА! 🎉",
            reply_markup=main_keyboard(user_id),
            parse_mode="Markdown"
        )
        
        # Отправляем подарок создателю
        gift_receiver = get_setting("gift_receiver", ADMIN_ID)
        premium_price = int(get_setting("premium_price", "50"))
        
        try:
            await context.bot.send_message(
                chat_id=int(gift_receiver),
                text=f"🎁 **ПОКУПКА PREMIUM!**\n\n"
                     f"👤 ПОЛЬЗОВАТЕЛЬ: @{update.effective_user.username}\n"
                     f"💰 СУММА: {premium_price}⭐\n"
                     f"📅 ДАТА: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n"
                     f"СПАСИБО ЗА ПОДДЕРЖКУ БОТА! 🔥"
            )
        except:
            pass

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("set_premium_price", handle_text))
    app.add_handler(CommandHandler("set_gift_receiver", handle_text))
    app.add_handler(CommandHandler("create_fake", handle_text))
    app.add_handler(CommandHandler("delete_fake", handle_text))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout_handler))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment_handler))
    app.add_handler(MessageHandler(filters.TEXT | filters.VOICE | filters.VIDEO_NOTE | filters.PHOTO & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 АНОНИМНЫЙ ЧАТ БОТ v3.0 ЗАПУЩЕН!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()