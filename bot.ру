            ticket_id = c.lastrowid
            conn.commit()
            conn.close()
            
            await update.message.reply_text(f"✅ Запрос принят! Номер: #{ticket_id}\nОтветит @{ADMIN_USERNAME}")
            
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"🆕 **Новый тикет #{ticket_id}**\n👤 @{username} (ID: {user_id})\n📝 {question}\n💡 /answer {ticket_id} [текст]"
            )
        except:
            await update.message.reply_text("Ошибка, попробуй позже.")
        context.user_data["awaiting_ticket"] = False

