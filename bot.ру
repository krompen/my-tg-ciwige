def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        gender TEXT DEFAULT 'не указан',
        age INTEGER DEFAULT 0,
        city TEXT DEFAULT '',
        lang TEXT DEFAULT 'ru',
        premium INTEGER DEFAULT 0,
        premium_until TEXT DEFAULT NULL,
        rating REAL DEFAULT 0,
        rating_count INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0,
        ban_reason TEXT DEFAULT NULL,
        registered_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS sessions (
        user_id INTEGER,
        partner_id INTEGER,
        start_time TEXT,
        PRIMARY KEY (user_id, partner_id)
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS queue (
        user_id INTEGER,
        gender TEXT,
        lang TEXT,
        premium INTEGER,
        search_gender TEXT,
        joined_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS reports (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        reporter_id INTEGER,
        reported_id INTEGER,
        reason TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS feedback (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        rating INTEGER,
        comment TEXT,
        created_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS fake_dialogs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user1_id INTEGER,
        user2_id INTEGER,
        created_at TEXT,
        status TEXT DEFAULT 'active'
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS bot_settings (
        key TEXT PRIMARY KEY,
        value TEXT
    )''')
    
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("search_timeout", "30")')
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("premium_price", "50")')
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("gift_receiver", "0")')
    
    c.execute('INSERT OR IGNORE INTO users (user_id, username, registered_at) VALUES (?, ?, ?)', 
              (ADMIN_ID, CREATOR_USERNAME, datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    
    conn.commit()
    conn.close()

init_db()

