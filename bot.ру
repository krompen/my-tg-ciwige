    )
    context.user_data["awaiting_trap"] = True

async def handle_trap(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("awaiting_trap"):
        tag = update.message.text.strip().lower()
        if not re.match(r'^[a-z]{3,10}$', tag):
            await update.message.reply_text("❌ Неверный тег. Только латиница, 3-10 букв.")
            return
        add_trap(update.effective_user.id, tag)
        await update.message.reply_text(f"✅ Ловушка на @{tag} поставлена! Как освободится — напишу.")
        context.user_data["awaiting_trap"] = False

