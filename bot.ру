# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        premium_level INTEGER DEFAULT 0,
        premium_until TEXT,
        daily_requests INTEGER DEFAULT 5,
        last_reset TEXT,
        total_requests INTEGER DEFAULT 0,
        ref_count INTEGER DEFAULT 0,
        ref_by INTEGER DEFAULT NULL,
        daily_bonus_last TEXT,
        is_banned INTEGER DEFAULT 0
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS found_tags (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        tag TEXT,
        found_date TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS traps (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        target_tag TEXT,
        status TEXT DEFAULT 'waiting',
        created_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS tickets (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        username TEXT,
        question TEXT,
        status TEXT DEFAULT 'open',
        created_at TEXT,
        admin_answer TEXT,
        answered_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS logs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        action TEXT,
        time TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS promocodes (
        code TEXT PRIMARY KEY,
        level INTEGER,
        days INTEGER,
        created_by INTEGER,
        created_at TEXT,
        used_count INTEGER DEFAULT 0,
        max_uses INTEGER DEFAULT 1,
        is_active INTEGER DEFAULT 1
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS used_promos (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        code TEXT,
        used_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS blacklist_tags (
        tag TEXT PRIMARY KEY
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS shop_tags (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        tag TEXT,
        price INTEGER,
        currency TEXT
    )''')
    conn.commit()
    conn.close()

