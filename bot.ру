# ========== РЕАЛЬНАЯ ПРОВЕРКА ТЕГА ==========
async def is_tag_available(tag):
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://t.me/{tag}", timeout=10) as resp:
                html = await resp.text()
                if "If you have Telegram, you can contact" in html:
                    return False
                if "join" in html.lower() or "login" in html.lower():
                    return True
                if f"@{tag}" in html:
                    return False
                return True
    except:
        return True

